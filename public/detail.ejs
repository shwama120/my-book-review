<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title><%= item.title %> - 상세 보기</title>
    <style>
        body { font-family: sans-serif; padding: 20px; line-height: 1.6; }
        .container { width: 500px; border: 1px solid #ccc; padding: 20px; background: #fafafa; }
        h1 { margin-top: 0; font-size: 1.8rem; }
        .info { color: #555; margin-bottom: 15px; font-size: 0.95rem; }
        .review-text { background: white; padding: 15px; border: 1px solid #ddd; min-height: 100px; }
        .back-btn { display: inline-block; margin-top: 20px; padding: 6px 12px; background: #333; color: white; text-decoration: none; font-size: 0.9rem; }
    </style>
</head>
<body>

    <div class="container">
        <h1><%= item.title %></h1>
        <div class="info">
            <strong>작가:</strong> <%= item.author %> | 
            <strong>분류:</strong> <%= item.category %> | 
            <strong>쪽수:</strong> <%= item.page_count || '미입력' %>쪽
        </div>
        
        <div class="review-text">
            <%= item.review || '작성된 감상평이 없습니다.' %>
        </div>

        <!-- [리다이렉트 링크] 누르면 다시 메인 목록 화면('/')으로 돌아감 -->
        <a href="/" class="back-btn">목록으로 돌아가기</a>
    </div>

</body>
</html>
